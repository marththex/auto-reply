# Environment variables for auto-reply. Everything is optional - the
# defaults assume a single-machine layout inside the repo checkout.
#
# The CLI tools read real environment variables (they do not load this
# file); docker compose reads a .env file sitting NEXT TO nas/compose.yaml.
# So: export the AUTOREPLY_* vars in your shell (or systemd unit), and
# `cp .env.example nas/.env` for the compose variables.

## draft-replies / training CLIs

# Inference backend: local (GPU via unsloth) or remote (llama.cpp server).
#AUTOREPLY_BACKEND=local

# llama.cpp server URL for the remote backend.
#AUTOREPLY_ENDPOINT=http://localhost:8080

# LoRA adapter directory used by draft-replies --backend local.
#AUTOREPLY_ADAPTER=models/adapter

# SQLite feedback DB path.
#AUTOREPLY_DB=data/autoreply.db

# Where export-gguf writes GGUF adapters + metadata. Point it at the
# volume your inference host mounts (network share, rsync target, ...).
#AUTOREPLY_MODELS_DIR=models/gguf

# llama.cpp checkout used by export-gguf (or pass --llama-cpp).
#LLAMA_CPP_DIR=../llama.cpp

## docker compose (nas/compose.yaml - put these in nas/.env)

# Host directory containing the base GGUF and adapters/ (mounted ro).
#MODELS_DIR=../models

# Host directory for the SQLite DB volume. Keep it on host-local disk;
# SQLite on a network share with two client hosts risks lock corruption.
#DATA_DIR=../data

# Host directory holding facts.yaml, allowlist.yaml and credentials/.
#CONFIG_DIR=..

# Host port the llama.cpp server listens on.
#LLAMA_PORT=8080

# Threads for llama-server; leave a few vCPUs free and benchmark.
#LLAMA_THREADS=4

# Base model GGUF filename under MODELS_DIR.
#BASE_GGUF=gemma-4-e2b-base-q5.gguf

# Adapter GGUF filename under MODELS_DIR/adapters (from export-gguf).
#ADAPTER_GGUF=adapter.gguf
